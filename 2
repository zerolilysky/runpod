def finalize_and_report(res_df: pd.DataFrame, pf_df: pd.DataFrame,
                        nav_store: dict, config: dict) -> None:
    line = "=" * 86
    print("\n" + line)
    print("  IV-SURFACE FORECAST RESULTS  (OOS %s .. %s, ranked by H-L Sharpe)"
          % (config["oos_start"][:7], config["oos_end"][:7]))
    print(line)
    if pf_df is None or pf_df.empty:
        print("  No portfolios produced.")
    else:
        cols = ["model", "sharpe_HL", "sharpe_HL_net", "cagr_HL", "maxdd_HL",
                "sharpe_long", "avg_turnover", "IC", "rankIC", "R2_is", "R2_oos"]
        for t in pf_df["target"].unique():
            sub = pf_df[pf_df["target"] == t].copy()
            print(f"\n--- target = {t} ---")
            with pd.option_context("display.float_format", lambda v: f"{v:,.4f}"):
                print(sub[[c for c in cols if c in sub.columns]].to_string(index=False))
    print(line + "\n")

    try:
        _make_figures(pf_df, nav_store, config)
    except Exception as exc:
        logging.warning("figures skipped: %s", exc)


def _make_figures(pf_df: pd.DataFrame, nav_store: dict, config: dict) -> None:
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    target = config["primary_target"]

    # (a) cumulative NAV of H-L by model (primary target) + market benchmark
    fig, ax = plt.subplots(figsize=(10, 4.5))
    plotted = False
    for (t, m), pf in nav_store.items():
        if t != target:
            continue
        nav = np.cumprod(1.0 + pf["HL"].values)
        ax.plot(pd.to_datetime(pf["date"]), nav, lw=1.4, label=m)
        plotted = True
    if plotted:
        ax.set_yscale("log")
        ax.set_title(f"Cumulative H-L NAV (log) — target {target}")
        ax.set_ylabel("growth of $1"); ax.legend(ncol=3, fontsize=8); ax.grid(alpha=0.3)
        fig.tight_layout()
        fig.savefig(os.path.join(config["fig_dir"], "nav_HL_by_model.png"), dpi=130)
    plt.close(fig)

    # (b) Sharpe-by-model bar chart per target
    if pf_df is not None and not pf_df.empty:
        for t in pf_df["target"].unique():
            sub = pf_df[pf_df["target"] == t].sort_values("sharpe_HL")
            fig, ax = plt.subplots(figsize=(8, 0.5 * len(sub) + 1.5))
            ax.barh(sub["model"], sub["sharpe_HL"])
            ax.set_title(f"Annualised H-L Sharpe — {t}")
            ax.axvline(0, color="k", lw=0.8); ax.grid(alpha=0.3, axis="x")
            fig.tight_layout()
            fig.savefig(os.path.join(config["fig_dir"],
                        f"sharpe_by_model_{t}.png"), dpi=130)
            plt.close(fig)

    # (c) IC bar chart (primary target)
    if pf_df is not None and not pf_df.empty:
        sub = pf_df[pf_df["target"] == target].sort_values("rankIC")
        if not sub.empty:
            fig, ax = plt.subplots(figsize=(8, 0.5 * len(sub) + 1.5))
            ax.barh(sub["model"], sub["rankIC"])
            ax.set_title(f"Cross-sectional rank-IC — {target}")
            ax.axvline(0, color="k", lw=0.8); ax.grid(alpha=0.3, axis="x")
            fig.tight_layout()
            fig.savefig(os.path.join(config["fig_dir"], "rankIC_by_model.png"), dpi=130)
            plt.close(fig)


def ensemble_size_sweep(model_name: str, target: str, config: dict = CONFIG,
                        Ks: Optional[List[int]] = None) -> pd.DataFrame:
    """Re-run one model at several ensemble sizes K and plot Sharpe vs K
    (paper Figure 5). Expensive; call explicitly."""
    panel, schema, _ = data_check(config)
    Ks = Ks or config["ensemble_sweep"]
    rows = []
    for K in Ks:
        cfg = {**config, "ensemble_K": K, "save_predictions": False}
        r = run_model_target(panel, schema, target, model_name, cfg)
        pp = r.get("pred_path")
        # run_model_target with save off still returns metrics; rebuild pf from rows
        # so re-enable save for the sweep:
        cfg2 = {**config, "ensemble_K": K}
        r = run_model_target(panel, schema, target, model_name, cfg2)
        pred_df = pd.read_parquet(r["pred_path"]) if os.path.exists(r["pred_path"]) \
            else pd.read_csv(r["pred_path"].replace(".parquet", ".csv"))
        pred_df["date"] = pd.to_datetime(pred_df["date"])
        pf = build_portfolio(pred_df, target, config)
        rows.append({"K": K, "sharpe_HL": pf["HL"]["sharpe_ann"],
                     "IC": r.get("IC", float("nan"))})
    sweep = pd.DataFrame(rows)
    sweep.to_csv(os.path.join(config["output_dir"],
                 f"ensemble_sweep_{model_name}_{target}.csv"), index=False)
    try:
        import matplotlib; matplotlib.use("Agg")
        import matplotlib.pyplot as plt
        fig, ax = plt.subplots(figsize=(7, 4))
        ax.plot(sweep["K"], sweep["sharpe_HL"], "o-")
        ax.set_xlabel("ensemble size K"); ax.set_ylabel("annualised H-L Sharpe")
        ax.set_title(f"Sharpe vs ensemble size — {model_name} / {target}")
        ax.grid(alpha=0.3); fig.tight_layout()
        fig.savefig(os.path.join(config["fig_dir"],
                    f"sharpe_vs_K_{model_name}_{target}.png"), dpi=130)
        plt.close(fig)
    except Exception:
        pass
    return sweep


