# ======================================================================
# Section 4 - Surface tensors + leak-free panel assembly
# ======================================================================
def assemble_panel(panel: pd.DataFrame, schema: Schema, target: str,
                   config: dict) -> dict:
    """
    Build the model-ready arrays for ONE target with no look-ahead:
      X     : (N, 1, n_maturity, n_delta) = (N,1,10,18) IV-surface images
      y     : (N,) forward return (already realised at feature_date + horizon)
      dates : (N,) FEATURE date (month-end t at which the surface is observed)
      ids   : (N,) stock id
    Rows with NaN target are dropped. Surface NaNs are imputed by the
    per-cell cross-sectional median WITHIN each month (causal: uses only that
    month's cross-section, never future data).
    """
    shape = schema.surface_shape
    n_cells = int(np.prod(shape))

    # extract the (N,180) surface for the WHOLE (already monthly) panel, then
    # drop rows with a missing target.
    S_all = extract_surface_matrix(panel, schema)            # (N,180) float32
    keep = pd.to_numeric(panel[target], errors="coerce").notna().to_numpy()
    S = S_all[keep]
    sub = panel.loc[keep, [schema.id_col, schema.date_col, target]].reset_index(drop=True)

    dcodes = pd.to_datetime(sub[schema.date_col]).dt.to_period("M").astype(str).values
    # causal NaN imputation: fill each surface cell with that month's median
    if np.isnan(S).any():
        tmp = pd.DataFrame(S)
        tmp["_m"] = dcodes
        med = tmp.groupby("_m").transform(lambda c: c.fillna(c.median()))
        S = np.nan_to_num(med.to_numpy(dtype=np.float32), nan=0.0)

    # leak-free surface standardisation (per the surface_norm policy)
    S = apply_surface_norm(S, dcodes, config)

    X = S.reshape(-1, 1, shape[0], shape[1]).astype(np.float32)
    y = pd.to_numeric(sub[target], errors="coerce").to_numpy(dtype=np.float32)
    dates = pd.DatetimeIndex(pd.to_datetime(sub[schema.date_col]).values)
    ids = sub[schema.id_col].to_numpy()

    mktcap = None
    if schema.mktcap_col is not None:
        mktcap = pd.to_numeric(panel.loc[keep, schema.mktcap_col],
                               errors="coerce").to_numpy(dtype=np.float64)
    return {"X": X, "y": y, "dates": dates, "ids": ids, "mktcap": mktcap,
            "n_features": n_cells, "surface_shape": shape}


def month_end_index(dates: pd.DatetimeIndex) -> pd.PeriodIndex:
    return dates.to_period("M")


def make_window_splits(dates: pd.DatetimeIndex, config: dict) -> List[dict]:
    """
    Produce a list of {train_mask, test_mask, test_period} dicts implementing
    the chosen window scheme. The split is BY FEATURE month; the embargo
    removes the last `embargo_months` of training so no training target's
    holding window (length = horizon) overlaps the first OOS feature month.

      * expanding : OOS month m trained on [start .. m-1-embargo]. If
                    `max_train_years` is set, the lookback is CAPPED to that many
                    years (a "capped expanding" window: expands until it reaches
                    the cap, then rolls forward keeping at most `max_train_years`).
      * rolling   : OOS month m trained on [m-roll_years .. m-1-embargo].
      * single    : one cut at oos_start (everything >= oos_start is test).
    """
    periods = month_end_index(dates)
    uniq = pd.PeriodIndex(sorted(periods.unique()))
    oos_start = pd.Period(pd.Timestamp(config["oos_start"]), "M")
    oos_end = pd.Period(pd.Timestamp(config["oos_end"]), "M")
    emb = int(config["embargo_months"])
    splits: List[dict] = []

    oos_months = [p for p in uniq if (p >= oos_start and p < oos_end)]

    if config["window_scheme"] == "single":
        train_cut = oos_start - emb
        tr = np.asarray(periods < train_cut)
        te = np.asarray((periods >= oos_start) & (periods < oos_end))
        splits.append({"train_mask": tr, "test_mask": te,
                       "test_period": "ALL"})
        return splits

    roll = int(config["roll_years"]) * 12
    cap = config.get("max_train_years")
    cap_months = int(cap) * 12 if cap else None     # optional expanding cap
    for m in oos_months:
        train_hi = m - emb            # exclusive upper bound on train feature month
        if config["window_scheme"] == "rolling":
            tr = (periods >= (m - roll)) & (periods < train_hi)
        else:  # expanding (optionally capped to a max trailing lookback)
            if cap_months is not None:
                tr = (periods >= (m - cap_months)) & (periods < train_hi)
            else:
                tr = periods < train_hi
        tr = np.asarray(tr)
        te = np.asarray(periods == m)
        if tr.sum() == 0 or te.sum() == 0:
            continue
        splits.append({"train_mask": tr, "test_mask": te,
                       "test_period": str(m)})
    return splits


# ======================================================================
# Section 5 - Standardisers (fit on TRAIN only -> no leakage)
# ======================================================================
class PixelScaler:
    """Per-pixel standardisation of (N,1,H,W) surfaces using train stats."""
    def fit(self, X: np.ndarray):
        self.mu_ = X.mean(axis=0, keepdims=True)
        self.sd_ = X.std(axis=0, keepdims=True)
        self.sd_[self.sd_ < EPS] = 1.0
        return self

    def transform(self, X: np.ndarray) -> np.ndarray:
        return ((X - self.mu_) / self.sd_).astype(np.float32)


class TargetScaler:
    def fit(self, y: np.ndarray):
        self.mu_ = float(np.mean(y))
        self.sd_ = float(np.std(y))
        if self.sd_ < EPS:
            self.sd_ = 1.0
        return self

    def transform(self, y: np.ndarray) -> np.ndarray:
        return ((y - self.mu_) / self.sd_).astype(np.float32)

    def inverse(self, y: np.ndarray) -> np.ndarray:
        return (np.asarray(y) * self.sd_ + self.mu_).astype(np.float32)


# ======================================================================
# Section 6 - Torch model zoo
# ----------------------------------------------------------------------
# All models map an IV-surface image (B,1,H,W) -> scalar prediction.
# Sequence models read the image as a length-H sequence of W-dim vectors
# (delta dimension = "time", maturity dimension = features), unless a CNN
# front-end produces the sequence (hybrids).
# ======================================================================
def _build_torch_modules():
    import torch
    import torch.nn as nn
    import torch.nn.functional as F

    def xavier_init(m):
        if isinstance(m, (nn.Linear, nn.Conv2d, nn.Conv1d)):
            nn.init.xavier_uniform_(m.weight)
            if m.bias is not None:
                nn.init.zeros_(m.bias)

    # ---------------- deepmlp (NAME KEPT AS "deepmlp") ----------------
    class DeepMLPRegressor(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            in_dim = int(np.prod(in_shape))
            hs = cfg["deepmlp_hidden"]
            layers, d = [], in_dim
            for h in hs:
                layers += [nn.Linear(d, h), nn.ReLU(),
                           nn.Dropout(cfg["deepmlp_dropout"])]
                d = h
            self.body = nn.Sequential(*layers)
            self.head = nn.Linear(d, 1)
            self.apply(xavier_init)

        def forward(self, x):
            x = x.flatten(1)
            return self.head(self.body(x)).squeeze(-1)

    # ---------------- generic 2D CNN ----------------------------------
    class CNNRegressor(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            chs = cfg["cnn_filters"]
            layers, c_in = [], in_shape[0]
            for c in chs:
                layers += [nn.Conv2d(c_in, c, 3, padding=1),
                           nn.BatchNorm2d(c), nn.ReLU(),
                           nn.MaxPool2d(2, ceil_mode=True),
                           nn.Dropout(cfg["cnn_dropout"])]
                c_in = c
            self.net = nn.Sequential(*layers)
            self.gap = nn.AdaptiveAvgPool2d(1)
            self.head = nn.Linear(c_in, 1)
            self.apply(xavier_init)

        def forward(self, x):
            x = self.net(x)
            x = self.gap(x).flatten(1)
            return self.head(x).squeeze(-1)

    # ---------------- paper CNN1 / CNN4 / CNN5 ------------------------
    class PaperCNN(nn.Module):
        """i conv blocks: 3x3 conv -> 2x2 maxpool -> BatchNorm -> ReLU,
        filters 16/32/64/128, then global-average-pool + single linear node.
        Matches Kelly et al. (2026) Fig. 3/4."""
        def __init__(self, in_shape, cfg, depth):
            super().__init__()
            filters = list(cfg["paper_filters"])
            # CNN1 uses 1 block (16); CNN4 uses 16/32/64/128; CNN5 repeats last.
            if depth <= len(filters):
                fs = filters[:depth]
            else:
                fs = filters + [filters[-1]] * (depth - len(filters))
            blocks, c_in = [], in_shape[0]
            for c in fs:
                blocks += [nn.Conv2d(c_in, c, 3, padding=1),
                           nn.MaxPool2d(2, ceil_mode=True),
                           nn.BatchNorm2d(c), nn.ReLU()]
                c_in = c
            self.net = nn.Sequential(*blocks)
            self.gap = nn.AdaptiveAvgPool2d(1)
            self.head = nn.Linear(c_in, 1)
            self.apply(xavier_init)

        def forward(self, x):
            x = self.net(x)
            x = self.gap(x).flatten(1)
            return self.head(x).squeeze(-1)

    def _seq_from_surface(x, reverse):
        """(B,1,maturity,delta) -> (B, maturity, delta) sequence. If reverse,
        order long->short maturity so the SHORTEST maturity is the LAST step."""
        seq = x.squeeze(1)              # (B, n_maturity, n_delta)
        if reverse:
            seq = torch.flip(seq, dims=[1])
        return seq

    # ---------------- LSTM (sequence over the MATURITY axis) ----------
    class LSTMRegressor(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            _, H, W = in_shape         # H = maturity steps, W = delta features
            self.rev = bool(cfg.get("seq_reverse_maturity", True))
            self.lstm = nn.LSTM(W, cfg["lstm_hidden"], cfg["lstm_layers"],
                                batch_first=True,
                                dropout=cfg["lstm_dropout"] if cfg["lstm_layers"] > 1 else 0.0)
            self.head = nn.Linear(cfg["lstm_hidden"], 1)
            self.apply(xavier_init)

        def forward(self, x):
            seq = _seq_from_surface(x, self.rev)   # short maturity = last step
            out, _ = self.lstm(seq)
            return self.head(out[:, -1, :]).squeeze(-1)

    # ---------------- Autoformer pieces -------------------------------
    class SeriesDecomp(nn.Module):
        """Moving-average trend/seasonal decomposition (Wu et al. 2021)."""
        def __init__(self, kernel):
            super().__init__()
            self.kernel = kernel
            self.avg = nn.AvgPool1d(kernel, stride=1, padding=0)

        def forward(self, x):                     # x: (B,L,D)
            pad = (self.kernel - 1) // 2
            front = x[:, :1, :].repeat(1, pad, 1)
            end = x[:, -1:, :].repeat(1, self.kernel - 1 - pad, 1)
            xp = torch.cat([front, x, end], dim=1)
            trend = self.avg(xp.transpose(1, 2)).transpose(1, 2)
            return x - trend, trend               # seasonal, trend

    class AutoCorrelation(nn.Module):
        """Simplified auto-correlation attention (FFT-based time-delay agg)."""
        def __init__(self, d_model, n_heads, dropout=0.1, factor=1):
            super().__init__()
            self.h = n_heads
            self.dk = d_model // n_heads
            self.factor = factor
            self.q = nn.Linear(d_model, d_model)
            self.k = nn.Linear(d_model, d_model)
            self.v = nn.Linear(d_model, d_model)
            self.out = nn.Linear(d_model, d_model)
            self.drop = nn.Dropout(dropout)

        def forward(self, x):
            B, L, _ = x.shape
            q = self.q(x).view(B, L, self.h, self.dk)
            k = self.k(x).view(B, L, self.h, self.dk)
            v = self.v(x).view(B, L, self.h, self.dk)
            # auto-correlation via FFT along time
            qf = torch.fft.rfft(q.permute(0, 2, 3, 1).contiguous(), dim=-1)
            kf = torch.fft.rfft(k.permute(0, 2, 3, 1).contiguous(), dim=-1)
            corr = torch.fft.irfft(qf * torch.conj(kf), n=L, dim=-1)  # (B,h,dk,L)
            corr = corr.mean(dim=2)                                   # (B,h,L) lag weights
            top = max(1, int(self.factor * math.log(max(L, 2))))
            w, idx = torch.topk(corr, top, dim=-1)                    # (B,h,top)
            w = torch.softmax(w, dim=-1)
            vp = v.permute(0, 2, 3, 1)                                # (B,h,dk,L)
            agg = torch.zeros_like(vp)
            ar = torch.arange(L, device=x.device).view(1, 1, 1, L)
            for i in range(top):
                shift = idx[:, :, i]                                  # (B,h)
                # vectorised time-delay roll per (B,h) via gather
                sh = shift.view(B, self.h, 1, 1)
                gidx = ((ar - sh) % L).expand(B, self.h, self.dk, L)
                rolled = torch.gather(vp, -1, gidx)
                agg = agg + rolled * w[:, :, i].view(B, self.h, 1, 1)
            agg = agg.permute(0, 3, 1, 2).contiguous().view(B, L, -1)
            return self.drop(self.out(agg))

    class AutoformerEncoderLayer(nn.Module):
        def __init__(self, d_model, n_heads, d_ff, kernel, dropout):
            super().__init__()
            self.attn = AutoCorrelation(d_model, n_heads, dropout)
            self.decomp1 = SeriesDecomp(kernel)
            self.decomp2 = SeriesDecomp(kernel)
            self.conv1 = nn.Conv1d(d_model, d_ff, 1)
            self.conv2 = nn.Conv1d(d_ff, d_model, 1)
            self.drop = nn.Dropout(dropout)
            self.act = nn.GELU()

        def forward(self, x):
            x = x + self.drop(self.attn(x))
            x, _ = self.decomp1(x)
            y = self.drop(self.act(self.conv1(x.transpose(1, 2))))
            y = self.drop(self.conv2(y).transpose(1, 2))
            x, _ = self.decomp2(x + y)
            return x

    class AutoformerRegressor(nn.Module):
        def __init__(self, in_shape, cfg, seq_dim=None):
            super().__init__()
            _, H, W = in_shape
            in_dim = seq_dim if seq_dim is not None else W
            self.rev = bool(cfg.get("seq_reverse_maturity", True))
            d = cfg["af_d_model"]
            self.embed = nn.Linear(in_dim, d)
            k = cfg["af_moving_avg"] | 1   # force odd
            self.layers = nn.ModuleList([
                AutoformerEncoderLayer(d, cfg["af_heads"], cfg["af_ff"], k,
                                       cfg["af_dropout"])
                for _ in range(cfg["af_layers"])])
            self.norm = nn.LayerNorm(d)
            self.head = nn.Linear(d, 1)
            self.apply(xavier_init)

        def _forward_seq(self, seq):     # seq already correctly ordered
            x = self.embed(seq)
            for lyr in self.layers:
                x = lyr(x)
            return self.head(self.norm(x).mean(dim=1)).squeeze(-1)

        def forward(self, x):
            return self._forward_seq(_seq_from_surface(x, self.rev))

    # ---------------- Echo State Network ------------------------------
    class ESNRegressor(nn.Module):
        """Reservoir computing: fixed random recurrent reservoir, trainable
        linear readout (trained by SGD inside the unified loop)."""
        def __init__(self, in_shape, cfg, seq_dim=None):
            super().__init__()
            _, H, W = in_shape
            in_dim = seq_dim if seq_dim is not None else W
            self.rev = bool(cfg.get("seq_reverse_maturity", True))
            n = cfg["esn_reservoir"]
            self.leak = cfg["esn_leak"]
            self.n = n
            g = torch.Generator().manual_seed(cfg.get("seed", 42))
            Win = (torch.rand(n, in_dim, generator=g) - 0.5) * 2.0
            W = torch.rand(n, n, generator=g) - 0.5
            mask = (torch.rand(n, n, generator=g) < cfg["esn_sparsity"]).float()
            W = W * mask
            # scale to desired spectral radius
            with torch.no_grad():
                ev = torch.linalg.eigvals(W).abs().max().item()
                if ev > 0:
                    W = W * (cfg["esn_spectral_radius"] / ev)
            self.register_buffer("Win", Win)
            self.register_buffer("Wres", W)
            self.readout = nn.Linear(n, 1)
            nn.init.xavier_uniform_(self.readout.weight); nn.init.zeros_(self.readout.bias)

        def _run(self, seq):                         # seq already ordered
            B, L, _ = seq.shape
            h = torch.zeros(B, self.n, device=seq.device)
            for t in range(L):
                pre = seq[:, t, :] @ self.Win.t() + h @ self.Wres.t()
                h = (1 - self.leak) * h + self.leak * torch.tanh(pre)
            return self.readout(h).squeeze(-1)

        def forward(self, x):
            return self._run(_seq_from_surface(x, self.rev))

    # ---------------- CNN front-end for hybrids -----------------------
    class CNNFront(nn.Module):
        """Conv2d feature extractor producing a (B, maturity, C) sequence for
        the temporal heads (collapsing the delta axis by mean). Reverses the
        maturity order so the shortest maturity is the last step."""
        def __init__(self, in_shape, cfg):
            super().__init__()
            self.rev = bool(cfg.get("seq_reverse_maturity", True))
            chs = cfg["cnn_filters"]
            layers, c_in = [], in_shape[0]
            for c in chs:
                layers += [nn.Conv2d(c_in, c, 3, padding=1),
                           nn.BatchNorm2d(c), nn.ReLU()]
                c_in = c
            self.net = nn.Sequential(*layers)
            self.out_ch = c_in

        def forward(self, x):
            f = self.net(x)                          # (B,C,maturity,delta)
            seq = f.mean(dim=3).transpose(1, 2)      # (B, maturity, C)
            if self.rev:
                seq = torch.flip(seq, dims=[1])      # short maturity = last step
            return seq

    class CNNLSTM(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            self.front = CNNFront(in_shape, cfg)
            self.lstm = nn.LSTM(self.front.out_ch, cfg["lstm_hidden"],
                                cfg["lstm_layers"], batch_first=True,
                                dropout=cfg["lstm_dropout"] if cfg["lstm_layers"] > 1 else 0.0)
            self.head = nn.Linear(cfg["lstm_hidden"], 1)
            self.apply(xavier_init)

        def forward(self, x):
            seq = self.front(x)
            out, _ = self.lstm(seq)
            return self.head(out[:, -1, :]).squeeze(-1)

    class CNNAutoformer(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            self.front = CNNFront(in_shape, cfg)
            self.af = AutoformerRegressor(in_shape, cfg, seq_dim=self.front.out_ch)

        def forward(self, x):
            seq = self.front(x)
            return self.af._forward_seq(seq)

    class CNNESN(nn.Module):
        def __init__(self, in_shape, cfg):
            super().__init__()
            self.front = CNNFront(in_shape, cfg)
            self.esn = ESNRegressor(in_shape, cfg, seq_dim=self.front.out_ch)

        def forward(self, x):
            seq = self.front(x)          # already maturity-ordered by the front
            return self.esn._run(seq)

    return {
        "deepmlp": lambda s, c: DeepMLPRegressor(s, c),
        "cnn":     lambda s, c: CNNRegressor(s, c),
        "cnn1":    lambda s, c: PaperCNN(s, c, depth=1),
        "cnn4":    lambda s, c: PaperCNN(s, c, depth=4),
        "cnn5":    lambda s, c: PaperCNN(s, c, depth=5),
        "lstm":    lambda s, c: LSTMRegressor(s, c),
        "autoformer": lambda s, c: AutoformerRegressor(s, c),
        "esn":     lambda s, c: ESNRegressor(s, c),
        "cnn-lstm": lambda s, c: CNNLSTM(s, c),
        "cnn-autoformer": lambda s, c: CNNAutoformer(s, c),
        "cnn-esn": lambda s, c: CNNESN(s, c),
    }


TORCH_MODELS = ["deepmlp", "cnn", "cnn1", "cnn4", "cnn5", "lstm",
                "autoformer", "esn", "cnn-lstm", "cnn-autoformer", "cnn-esn"]
SKLEARN_MODELS = ["rf"]


# ======================================================================
# Section 7 - Training utilities (warm-up + transfer learning, ensembling)
# ======================================================================
def _iter_batches(n: int, bs: int, shuffle: bool, generator=None):
    import torch
    idx = torch.randperm(n, generator=generator) if shuffle else torch.arange(n)
    batches, s = [], 0
    while s < n:
        e = min(s + bs, n)
        batches.append(idx[s:e]); s = e
    if len(batches) >= 2 and len(batches[-1]) == 1:   # avoid singleton (BatchNorm)
        last = batches.pop()
        batches[-1] = torch.cat([batches[-1], last])
    return batches


def _train_epochs(model, Xtr, ytr, Xvl, yvl, n_epochs, config, device, seed,
                  early_stop: bool):
    """Train `model` for n_epochs on (Xtr,ytr). If early_stop, keep the best
    state on the chronological validation tail (Xvl,yvl)."""
    import torch
    import torch.nn.functional as F
    import torch.optim as optim

    amp = bool(config.get("use_amp", True)) and device.type == "cuda"
    bs = config["batch_size"]
    model.to(device)
    Xtr_t = torch.from_numpy(Xtr).to(device)
    ytr_t = torch.from_numpy(ytr).to(device)
    has_val = early_stop and len(Xvl) > 0
    if has_val:
        Xvl_t = torch.from_numpy(Xvl).to(device)
        yvl_t = torch.from_numpy(yvl).to(device)

    try:
        opt = optim.AdamW(model.parameters(), lr=config["lr"],
                          weight_decay=config["weight_decay"],
                          fused=(device.type == "cuda"))
    except Exception:
        opt = optim.AdamW(model.parameters(), lr=config["lr"],
                          weight_decay=config["weight_decay"])
    scaler = torch.cuda.amp.GradScaler(enabled=amp)
    rng = torch.Generator(device="cpu").manual_seed(seed)

    best_val = float("inf"); best_state = None; wait = 0
    n = len(Xtr_t)
    for _ in range(n_epochs):
        model.train()
        for idx in _iter_batches(n, bs, shuffle=True, generator=rng):
            idx = idx.to(device)
            opt.zero_grad(set_to_none=True)
            with torch.cuda.amp.autocast(enabled=amp):
                pred = model(Xtr_t[idx])
                loss = F.mse_loss(pred, ytr_t[idx])
            scaler.scale(loss).backward()
            scaler.step(opt); scaler.update()
        if has_val:
            model.eval()
            with torch.no_grad(), torch.cuda.amp.autocast(enabled=amp):
                vloss = F.mse_loss(model(Xvl_t), yvl_t).item()
            if np.isfinite(vloss) and vloss < best_val - 1e-9:
                best_val = vloss
                best_state = {k: v.detach().clone() for k, v in model.state_dict().items()}
                wait = 0
            else:
                wait += 1
            if wait >= config["patience"]:
                break
    if has_val and best_state is not None:
        model.load_state_dict(best_state)
    return model


def _predict(model, X, device, bs=4096):
    import torch
    model.eval()
    outs = []
    with torch.no_grad():
        for s in range(0, len(X), bs):
            xb = torch.from_numpy(X[s:s + bs]).to(device)
            outs.append(model(xb).detach().cpu().numpy().reshape(-1))
    return np.concatenate(outs) if outs else np.empty((0,), np.float32)


# ======================================================================
# Section 8 - Metrics (regression + cross-sectional IC)
# ======================================================================
def regression_metrics(y_true: np.ndarray, y_pred: np.ndarray) -> Dict[str, float]:
    y_true = np.asarray(y_true, np.float64).reshape(-1)
    y_pred = np.asarray(y_pred, np.float64).reshape(-1)
    err = y_true - y_pred
    mae = float(np.abs(err).mean())
    rmse = float(np.sqrt((err ** 2).mean()))
    ss_res = float((err ** 2).sum())
    ss_tot = float(((y_true - y_true.mean()) ** 2).sum())
    r2 = float(1.0 - ss_res / ss_tot) if ss_tot > 0 else float("nan")
    return {"MAE": mae, "RMSE": rmse, "R2": r2, "n_test": int(len(y_true))}


def information_coefficients(pred_df: pd.DataFrame) -> Dict[str, float]:
    """Mean monthly Pearson IC and Spearman rank-IC of predictions vs realised."""
    ics, rics = [], []
    for _, g in pred_df.groupby("date"):
        if len(g) < 5:
            continue
        a, b = g["y_pred"].values, g["y_true"].values
        if np.std(a) < EPS or np.std(b) < EPS:
            continue
        ics.append(np.corrcoef(a, b)[0, 1])
        ra = pd.Series(a).rank().values
        rb = pd.Series(b).rank().values
        rics.append(np.corrcoef(ra, rb)[0, 1])
    return {"IC": float(np.mean(ics)) if ics else float("nan"),
            "ICIR": float(np.mean(ics) / (np.std(ics) + EPS)) if ics else float("nan"),
            "rankIC": float(np.mean(rics)) if rics else float("nan")}


# ======================================================================
# Section 9 - Per-(target, model) OOS runner
# ----------------------------------------------------------------------
# Produces an out-of-sample prediction panel [date, id, y_true, y_pred(_k)]
# following the chosen window scheme with strict leak-free scaling.
# Neural models use warm-up + transfer learning with PERSISTENT weights across
# months (paper). RF refits per window. Ensemble = mean over K seeds.
# ======================================================================
def run_model_target(panel: pd.DataFrame, schema: Schema, target: str,
                     model_name: str, config: dict, force_cpu: bool = False,
                     n_threads: Optional[int] = None) -> dict:
    t0 = time.time()
    data = assemble_panel(panel, schema, target, config)
    X, y, dates, ids = data["X"], data["y"], data["dates"], data["ids"]
    in_shape = (1, data["surface_shape"][0], data["surface_shape"][1])
    splits = make_window_splits(dates, config)
    if not splits:
        return {"target": target, "model": model_name, "error": "no splits"}

    K = int(config["ensemble_K"])
    base_seed = int(config["seed"])
    is_torch = model_name in TORCH_MODELS
    rows = []                      # collected OOS prediction rows
    is_true = is_pred = None       # in-sample (last training window) for R2_is

    if is_torch:
        import torch
        cpu_only = force_cpu or not config.get("use_cuda", False)
        device = torch.device("cpu") if cpu_only else resolve_device(config)
        if device.type == "cuda":
            _maybe_cap_gpu_memory(config)
        if n_threads is not None:               # pinned by the CPU scheduler
            try:
                torch.set_num_threads(max(1, int(n_threads)))
            except Exception:
                pass
        else:
            configure_threads(config, divisor=(config["n_workers"] if force_cpu else 1))
        builders = _build_torch_modules()
        members = [None] * K           # persistent models across splits
        refit_every = max(1, int(config.get("refit_every", 1)))
        ps_ref = ts_ref = None         # scalers from the LAST refit (reused between)
        first_refit = True
        si = 0                         # index over processed OOS months
        for sp in splits:
            tr, te = sp["train_mask"], sp["test_mask"]
            Xtr_all, ytr_all = X[tr], y[tr]
            Xte = X[te]
            if len(Xtr_all) < 8 or len(Xte) == 0:
                continue
            do_refit = first_refit or (si % refit_every == 0)
            if do_refit:
                # (re)fit scalers + train/fine-tune the ensemble on this window
                ps = PixelScaler().fit(Xtr_all)
                ts = TargetScaler().fit(ytr_all)
                Xtr_s = ps.transform(Xtr_all); ytr_s = ts.transform(ytr_all)
                n_tr = len(Xtr_s)
                n_val = max(1, int(round(n_tr * config["val_frac"]))) if first_refit else 0
                n_sub = n_tr - n_val
                Xsub, ysub = Xtr_s[:n_sub], ytr_s[:n_sub]
                Xval, yval = Xtr_s[n_sub:], ytr_s[n_sub:]
                is_k = np.zeros(len(Xtr_s), np.float64)
                for k in range(K):
                    seed = base_seed + k
                    if members[k] is None:
                        set_seed(seed)
                        members[k] = builders[model_name](in_shape, {**config, "seed": seed})
                    epochs = config["warmup_epochs"] if first_refit else config["transfer_epochs"]
                    members[k] = _train_epochs(members[k], Xsub, ysub, Xval, yval,
                                               epochs, config, device, seed,
                                               early_stop=first_refit)
                    is_k += ts.inverse(_predict(members[k], Xtr_s, device))
                is_true, is_pred = ytr_all.copy(), is_k / K   # IS from last refit
                ps_ref, ts_ref = ps, ts
                first_refit = False
            # predict this OOS month with the current (possibly held) ensemble,
            # using the scalers the models were trained with (leak-free).
            Xte_s = ps_ref.transform(Xte)
            preds_k = np.zeros(len(Xte_s), np.float64)
            for k in range(K):
                preds_k += ts_ref.inverse(_predict(members[k], Xte_s, device))
            preds_k /= K
            for j, gi in enumerate(np.where(te)[0]):
                rows.append((dates[gi], ids[gi], float(y[gi]), float(preds_k[j])))
            si += 1
            gc.collect()
            if device.type == "cuda":
                torch.cuda.empty_cache()
        del members
        gc.collect()

    else:   # ---- RandomForest (sklearn) -----------------------------
        from sklearn.ensemble import RandomForestRegressor
        refit_every = max(1, int(config.get("refit_every", 1)))
        rf_models = None               # held between refits
        first_refit = True
        si = 0
        n_est = max(1, int(config["rf_estimators"]))
        rf_jobs = int(n_threads) if n_threads else (1 if force_cpu else -1)
        for sp in splits:
            tr, te = sp["train_mask"], sp["test_mask"]
            Xtr_all, ytr_all = X[tr], y[tr]
            Xte = X[te]
            if len(Xtr_all) < 8 or len(Xte) == 0:
                continue
            Xte_f = Xte.reshape(len(Xte), -1)
            do_refit = first_refit or (si % refit_every == 0)
            if do_refit:
                Xtr_f = Xtr_all.reshape(len(Xtr_all), -1)
                rf_models, is_k = [], np.zeros(len(Xtr_f), np.float64)
                for k in range(K):
                    rf = RandomForestRegressor(
                        n_estimators=n_est, max_depth=config["rf_max_depth"],
                        max_features=config["rf_max_features"],
                        n_jobs=rf_jobs, random_state=base_seed + k)
                    rf.fit(Xtr_f, ytr_all)
                    rf_models.append(rf)
                    is_k += rf.predict(Xtr_f)
                is_true, is_pred = ytr_all.copy(), is_k / K
                first_refit = False
            preds_k = np.zeros(len(Xte_f), np.float64)
            for rf in rf_models:
                preds_k += rf.predict(Xte_f)
            preds_k /= len(rf_models)
            for j, gi in enumerate(np.where(te)[0]):
                rows.append((dates[gi], ids[gi], float(y[gi]), float(preds_k[j])))
            si += 1

    if not rows:
        return {"target": target, "model": model_name, "error": "no OOS rows"}

    pred_df = pd.DataFrame(rows, columns=["date", "id", "y_true", "y_pred"])
    pred_df = pred_df.sort_values(["date", "id"]).reset_index(drop=True)
    if config.get("save_predictions", True):
        fn = os.path.join(config["output_dir"], f"pred_{target}_{model_name}.parquet")
        try:
            pred_df.to_parquet(fn)
        except Exception:
            pred_df.to_csv(fn.replace(".parquet", ".csv"), index=False)

    metrics = regression_metrics(pred_df["y_true"], pred_df["y_pred"])
    metrics["R2_oos"] = metrics.pop("R2")          # the concatenated-OOS R^2
    metrics.update(information_coefficients(pred_df))
    # in-sample R^2 on the final training window (diagnostic for over/under-fit)
    if is_true is not None and is_pred is not None and len(is_true) > 1:
        metrics["R2_is"] = regression_metrics(is_true, is_pred)["R2"]
    else:
        metrics["R2_is"] = float("nan")
    elapsed = time.time() - t0
    logging.info("done %s/%-14s | IC=%.4f rankIC=%.4f R2_is=%.4f R2_oos=%.4f (%.1fs)",
                 target, model_name, metrics.get("IC", float("nan")),
                 metrics.get("rankIC", float("nan")),
                 metrics["R2_is"], metrics["R2_oos"], elapsed)
    return {"target": target, "model": model_name, **metrics,
            "train_secs": round(elapsed, 2), "pred_path":
            os.path.join(config["output_dir"], f"pred_{target}_{model_name}.parquet")}


# ======================================================================
# Section 10 - Portfolio construction & performance
# ----------------------------------------------------------------------
# Each month: sort stocks into deciles by predicted return; equal- (or value-)
# weight; long top decile, short bottom decile (H-L), 1-period holding.
# Reports annualised Sharpe, mean, vol, turnover, max drawdown, cumulative NAV.
# Annualisation uses periods_per_year = 252 / horizon_days.
# ======================================================================
def _periods_per_year(target: str, config: dict) -> float:
    h = config["target_horizon_days"].get(target, 21)
    return 252.0 / float(h)


def _infer_ppy(dates: pd.Series, target: str, config: dict) -> float:
    """Annualisation factor from the ACTUAL rebalance cadence (monthly data ->
    ~12). Falls back to 252/horizon if the cadence can't be inferred."""
    u = pd.to_datetime(pd.Index(pd.Series(dates).unique())).sort_values()
    if len(u) > 2:
        gap = np.median(np.diff(u.values).astype("timedelta64[D]").astype(float))
        if gap >= 1.0:
            return 365.25 / gap
    return _periods_per_year(target, config)


def _max_drawdown(nav: np.ndarray) -> float:
    peak = np.maximum.accumulate(nav)
    return float((nav / peak - 1.0).min())


def _to_monthly_predictions(pred_df: pd.DataFrame) -> pd.DataFrame:
    """Collapse predictions to ONE row per (stock, month): the last (month-end)
    observation. This is where sub-monthly training data becomes a monthly
    portfolio (resample to monthly only at portfolio construction)."""
    df = pred_df.copy()
    df["date"] = pd.to_datetime(df["date"])
    df["_m"] = df["date"].dt.to_period("M")
    idx = df.groupby(["id", "_m"])["date"].idxmax()
    out = df.loc[idx].copy()
    out["date"] = out["_m"].dt.to_timestamp("M")     # align all stocks to month-end
    return out.drop(columns="_m").sort_values(["date", "id"]).reset_index(drop=True)


def build_portfolio(pred_df: pd.DataFrame, target: str, config: dict,
                    weights_lookup: Optional[dict] = None) -> dict:
    n_dec = int(config["n_deciles"])
    if config.get("portfolio_monthly", True):
        pred_df = _to_monthly_predictions(pred_df)
    ppy = _infer_ppy(pred_df["date"], target, config)
    tcost = config["tcost_bps"] / 1e4

    monthly = []
    prev_long, prev_short = set(), set()
    for dt, g in pred_df.groupby("date"):
        g = g.dropna(subset=["y_pred", "y_true"])
        if len(g) < n_dec * 2:
            continue
        ranks = g["y_pred"].rank(method="first")
        q_hi = ranks.quantile(1 - 1.0 / n_dec)
        q_lo = ranks.quantile(1.0 / n_dec)
        long_ = g[ranks >= q_hi]
        short_ = g[ranks <= q_lo]
        if config["weighting"] == "value" and weights_lookup is not None:
            def _w(sub):
                w = np.array([max(weights_lookup.get((r["id"], dt), np.nan), 0)
                              for _, r in sub.iterrows()], float)
                if np.all(~np.isfinite(w)) or np.nansum(w) <= 0:
                    w = np.ones(len(sub))
                w = np.nan_to_num(w, nan=0.0)
                return w / w.sum()
            wl, ws = _w(long_), _w(short_)
            r_long = float((long_["y_true"].values * wl).sum())
            r_short = float((short_["y_true"].values * ws).sum())
        else:
            r_long = float(long_["y_true"].mean())
            r_short = float(short_["y_true"].mean())
        cur_long, cur_short = set(long_["id"]), set(short_["id"])
        # turnover = fraction of legs replaced vs previous period
        to_long = 1.0 - len(cur_long & prev_long) / max(len(cur_long), 1)
        to_short = 1.0 - len(cur_short & prev_short) / max(len(cur_short), 1)
        turnover = 0.5 * (to_long + to_short)
        hl = r_long - r_short
        hl_net = hl - tcost * turnover * 2.0
        monthly.append({"date": dt, "long": r_long, "short": r_short,
                        "HL": hl, "HL_net": hl_net, "turnover": turnover,
                        "n": len(g)})
        prev_long, prev_short = cur_long, cur_short

    if not monthly:
        return {"error": "insufficient cross-section for portfolios"}
    pf = pd.DataFrame(monthly).sort_values("date").reset_index(drop=True)

    def _stats(col):
        r = pf[col].values
        mu, sd = float(r.mean()), float(r.std(ddof=1) if len(r) > 1 else 0.0)
        sharpe = float(mu / sd * math.sqrt(ppy)) if sd > EPS else float("nan")
        nav = np.cumprod(1.0 + r)
        cagr = float(nav[-1] ** (ppy / len(r)) - 1.0) if len(r) > 0 else float("nan")
        return {"mean_period": mu, "vol_period": sd, "sharpe_ann": sharpe,
                "cagr": cagr, "maxdd": _max_drawdown(nav), "n_periods": len(r)}

    out = {"target": target,
           "HL": _stats("HL"), "HL_net": _stats("HL_net"),
           "long": _stats("long"), "short": _stats("short"),
           "avg_turnover": float(pf["turnover"].mean()),
           "monthly": pf}
    return out


def build_mktcap_lookup(panel: pd.DataFrame, schema: Schema) -> Optional[dict]:
    if schema.mktcap_col is None:
        return None
    sub = panel[[schema.id_col, schema.date_col, schema.mktcap_col]].dropna()
    return {(r[schema.id_col], pd.Timestamp(r[schema.date_col])): float(r[schema.mktcap_col])
            for _, r in sub.iterrows()}


def size_group_analysis(pred_df: pd.DataFrame, panel: pd.DataFrame, schema: Schema,
                        target: str, config: dict) -> Optional[pd.DataFrame]:
    """Split the H-L Sharpe by size group using cross-sectional mktcap
    breakpoints (mega>=80%, large 50-80%, small 20-50%, micro<20%, non-micro>=20%)."""
    if schema.mktcap_col is None:
        return None
    cap = panel[[schema.id_col, schema.date_col, schema.mktcap_col]].copy()
    cap[schema.date_col] = pd.to_datetime(cap[schema.date_col])
    cap = cap.rename(columns={schema.id_col: "id", schema.date_col: "date",
                              schema.mktcap_col: "cap"})
    merged = pred_df.merge(cap, on=["id", "date"], how="left").dropna(subset=["cap"])
    if merged.empty:
        return None
    # monthly breakpoints
    def _grp(g):
        q20, q50, q80 = g["cap"].quantile([0.2, 0.5, 0.8])
        cond = [g["cap"] >= q80, (g["cap"] >= q50) & (g["cap"] < q80),
                (g["cap"] >= q20) & (g["cap"] < q50), g["cap"] < q20]
        g = g.copy()
        g["sizegrp"] = np.select(cond, ["mega", "large", "small", "micro"], "micro")
        return g
    merged = merged.groupby("date", group_keys=False).apply(_grp)
    rows = []
    groups = {"mega": ["mega"], "large": ["large"], "small": ["small"],
              "micro": ["micro"], "non-micro": ["mega", "large", "small"]}
    for name, members in groups.items():
        sub = merged[merged["sizegrp"].isin(members)]
        pf = build_portfolio(sub[["date", "id", "y_true", "y_pred"]], target, config)
        if "error" not in pf:
            rows.append({"size_group": name, **{f"HL_{k}": v
                         for k, v in pf["HL"].items()}})
    return pd.DataFrame(rows) if rows else None


