def build_task_list(config: dict) -> List[dict]:
    tasks = []
    for t, m in product(config["targets"], config["models"]):
        tasks.append({"target": t, "model": m})
    return tasks


def _pin_blas_threads(n: int) -> None:
    """Cap BLAS/OpenMP threads so concurrent workers don't oversubscribe."""
    for v in ("OMP_NUM_THREADS", "OPENBLAS_NUM_THREADS", "MKL_NUM_THREADS",
              "NUMEXPR_NUM_THREADS", "VECLIB_MAXIMUM_THREADS"):
        os.environ[v] = str(max(1, int(n)))


def _load_panel_and_schema(config: dict) -> Tuple[pd.DataFrame, Schema]:
    """Reload the cached panel + resolve schema (used by pool workers so the
    big DataFrame is read from disk, not pickled across processes). Applies the
    SAME subset + monthly resample as data_check so workers see an identical
    panel to the parent."""
    panel = load_raw_panel(config)
    schema = resolve_schema(panel, config)
    panel[schema.date_col] = pd.to_datetime(panel[schema.date_col])
    panel = panel.sort_values([schema.date_col, schema.id_col]).reset_index(drop=True)
    panel = apply_stock_subset(panel, schema, config)
    if config.get("resample_monthly", True):
        panel = resample_to_monthly(panel, schema)
    return panel, schema


def _cpu_worker(args):
    panel, schema, task, config, n_threads = args
    if n_threads is not None:
        _pin_blas_threads(n_threads)
    try:
        if panel is None:          # reload from cache inside the worker
            panel, schema = _load_panel_and_schema(config)
        return run_model_target(panel, schema, task["target"], task["model"],
                                config, force_cpu=True, n_threads=n_threads)
    except Exception as exc:
        logging.error("task %s failed: %s", task, exc, exc_info=True)
        return {"target": task["target"], "model": task["model"], "error": str(exc)}


def plan_cpu_allocation(n_tasks: int, n_cpus: int) -> Tuple[int, int]:
    """Cores -> models policy:
       * more models than cores -> one model per core, 1 thread each (queued);
       * otherwise              -> split cores evenly across models.
    Returns (max_workers, threads_per_model)."""
    n_cpus = max(1, int(n_cpus))
    n_tasks = max(1, int(n_tasks))
    if n_tasks >= n_cpus:
        return n_cpus, 1
    return n_tasks, max(1, n_cpus // n_tasks)


def run_grid(config: dict = CONFIG) -> pd.DataFrame:
    panel, schema, _ = data_check(config)
    config["force_rebuild"] = False        # cache now written; workers read it
    tasks = build_task_list(config)
    n_cpus = int(config.get("n_cpus") or os.cpu_count() or 1)
    cpu_mode = not config.get("use_cuda", False)
    logging.info("Grid: %d tasks (%d targets x %d models) | %s",
                 len(tasks), len(config["targets"]), len(config["models"]),
                 f"CPU-distributed over {n_cpus} cores" if cpu_mode else "GPU mode")
    results: List[dict] = []

    if cpu_mode and len(tasks) > 1:
        # ---- distributed: every model trains concurrently across cores ----
        max_workers, threads_per = plan_cpu_allocation(len(tasks), n_cpus)
        logging.info("CPU schedule: %d concurrent workers x %d thread(s)/model "
                     "(%d tasks, %d cores)", max_workers, threads_per,
                     len(tasks), n_cpus)
        _pin_blas_threads(threads_per)            # children inherit via spawn
        import multiprocessing as mp
        from concurrent.futures import ProcessPoolExecutor, as_completed
        ctx = mp.get_context("spawn")
        with ProcessPoolExecutor(max_workers=max_workers, mp_context=ctx) as ex:
            # panel=None -> each worker reloads from the disk cache (avoids
            # pickling the full panel to every process).
            futs = [ex.submit(_cpu_worker, (None, None, t, config, threads_per))
                    for t in tasks]
            for fut in as_completed(futs):
                results.append(fut.result())
    elif cpu_mode:
        # single task -> give it every core
        t = tasks[0]
        _pin_blas_threads(n_cpus)
        results.append(run_model_target(panel, schema, t["target"], t["model"],
                                        config, force_cpu=True, n_threads=n_cpus))
    else:
        # ---- GPU mode: neural sequential on GPU, rf fans out on CPU pool ----
        cpu_tasks = [t for t in tasks if t["model"] in SKLEARN_MODELS]
        gpu_tasks = [t for t in tasks if t["model"] in TORCH_MODELS]
        n_workers = max(1, int(config.get("n_workers", 1)))
        if cpu_tasks and n_workers > 1:
            import multiprocessing as mp
            from concurrent.futures import ProcessPoolExecutor, as_completed
            ctx = mp.get_context("spawn")
            with ProcessPoolExecutor(max_workers=n_workers, mp_context=ctx) as ex:
                futs = [ex.submit(_cpu_worker, (panel, schema, t, config, None))
                        for t in cpu_tasks]
                for fut in as_completed(futs):
                    results.append(fut.result())
        else:
            for t in cpu_tasks:
                results.append(run_model_target(panel, schema, t["target"],
                                                t["model"], config))
        for t in gpu_tasks:     # sequential on the GPU
            results.append(run_model_target(panel, schema, t["target"],
                                            t["model"], config))

    res_df = pd.DataFrame(results)
    res_df.to_csv(os.path.join(config["output_dir"], "results_all.csv"), index=False)

    # ---- portfolios + analysis for every successful run ----------
    portfolio_rows = []
    nav_store = {}
    for r in results:
        if "error" in r and r.get("pred_path") is None:
            continue
        pp = r.get("pred_path")
        if not pp or not (os.path.exists(pp) or os.path.exists(pp.replace(".parquet", ".csv"))):
            continue
        try:
            pred_df = (pd.read_parquet(pp) if os.path.exists(pp)
                       else pd.read_csv(pp.replace(".parquet", ".csv")))
            pred_df["date"] = pd.to_datetime(pred_df["date"])
        except Exception:
            continue
        wl = build_mktcap_lookup(panel, schema) if config["weighting"] == "value" else None
        pf = build_portfolio(pred_df, r["target"], config, wl)
        if "error" in pf:
            continue
        portfolio_rows.append({
            "target": r["target"], "model": r["model"],
            "sharpe_HL": pf["HL"]["sharpe_ann"],
            "sharpe_HL_net": pf["HL_net"]["sharpe_ann"],
            "cagr_HL": pf["HL"]["cagr"], "maxdd_HL": pf["HL"]["maxdd"],
            "sharpe_long": pf["long"]["sharpe_ann"],
            "avg_turnover": pf["avg_turnover"],
            "IC": r.get("IC", float("nan")), "rankIC": r.get("rankIC", float("nan")),
            "R2_is": r.get("R2_is", float("nan")), "R2_oos": r.get("R2_oos", float("nan")),
        })
        nav_store[(r["target"], r["model"])] = pf["monthly"]
        # size groups for the primary target
        if config.get("size_groups") and r["target"] == config["primary_target"]:
            sg = size_group_analysis(pred_df, panel, schema, r["target"], config)
            if sg is not None:
                sg.insert(0, "model", r["model"])
                sg.to_csv(os.path.join(config["output_dir"],
                          f"sizegroups_{r['model']}.csv"), index=False)

    pf_df = pd.DataFrame(portfolio_rows)
    if not pf_df.empty:
        pf_df = pf_df.sort_values(["target", "sharpe_HL"], ascending=[True, False])
        pf_df.to_csv(os.path.join(config["output_dir"], "portfolio_summary.csv"), index=False)

    finalize_and_report(res_df, pf_df, nav_store, config)
    return pf_df


