def _ci_lookup(columns: Sequence[str], candidates: Sequence[str]) -> Optional[str]:
    """Case-insensitive: return the actual column matching any candidate."""
    lower = {c.lower(): c for c in columns}
    for cand in candidates:
        if cand.lower() in lower:
            return lower[cand.lower()]
    return None


def list_data_files(config: dict) -> List[str]:
    pat = os.path.join(config["data_dir"], config["file_glob"])
    files = sorted(glob.glob(pat))
    return files


def _read_one(path: str) -> pd.DataFrame:
    if path.endswith((".pickle", ".pkl")):
        df = pd.read_pickle(path)
    elif path.endswith(".parquet"):
        df = pd.read_parquet(path)
    elif path.endswith(".csv"):
        df = pd.read_csv(path)
    else:
        raise ValueError(f"Unsupported file type: {path}")
    if not isinstance(df, pd.DataFrame):
        df = pd.DataFrame(df)
    return df


def _cache_path_for(config: dict) -> str:
    """Cache filename keyed to the data folder + file set, so switching data
    (or adding files) auto-invalidates the cache instead of serving a stale
    panel. `--force-rebuild` still overrides."""
    import hashlib
    files = list_data_files(config)
    key = "|".join([os.path.abspath(config.get("data_dir", "."))] +
                   [os.path.basename(f) for f in files])
    h = hashlib.md5(key.encode()).hexdigest()[:10]
    base = config["combined_cache"]
    return base.replace(".parquet", f"_{h}.parquet")


def load_raw_panel(config: dict = CONFIG) -> pd.DataFrame:
    """
    Load and concatenate all per-stock files into a single tidy panel.
    Cached to parquet (falls back to pickle). Does NOT rename columns; the
    data-check stage resolves the canonical names.
    """
    cache = _cache_path_for(config)
    cache_pkl = cache.replace(".parquet", ".pkl")
    if not config.get("force_rebuild", False):
        if os.path.exists(cache):
            try:
                return pd.read_parquet(cache)
            except Exception:
                pass
        if os.path.exists(cache_pkl):
            return pd.read_pickle(cache_pkl)

    files = list_data_files(config)
    if not files:
        raise FileNotFoundError(
            f"No files matched {os.path.join(config['data_dir'], config['file_glob'])}. "
            f"Set CONFIG['data_dir'] / CONFIG['file_glob'] to your OptionMetrics files."
        )
    logging.info("Loading %d data file(s) ...", len(files))
    frames = []
    for f in files:
        d = _read_one(f)
        d["_src_file"] = os.path.basename(f)
        frames.append(d)
    panel = pd.concat(frames, axis=0, ignore_index=True)
    logging.info("Combined panel: %d rows x %d cols", len(panel), panel.shape[1])

    os.makedirs(os.path.dirname(cache), exist_ok=True)
    try:
        panel.to_parquet(cache)
    except Exception as exc:
        logging.warning("parquet unavailable (%s) -> pickle cache", exc)
        panel.to_pickle(cache_pkl)
    return panel


# ======================================================================
# Section 3 - DATA CHECK & SUMMARY  (run BEFORE any training)
# ----------------------------------------------------------------------
# Resolves canonical column names, locates the 180 surface cells, verifies
# they reshape to 10x18, summarises coverage / missingness / target stats,
# and writes a JSON + CSV + a few diagnostic figures. Designed to surface
# any naming / formatting / shape mismatch loudly and early.
# ======================================================================
class Schema:
    """Resolved column layout for the panel."""
    def __init__(self):
        self.id_col: str = ""
        self.date_col: str = ""
        self.trade_id_col: Optional[str] = None
        self.mktcap_col: Optional[str] = None
        self.surface_list_col: Optional[str] = None   # single list-valued column
        self.surface_cols: List[str] = []             # OR 180 separate columns
        self.target_cols: List[str] = []
        self.surface_shape: Tuple[int, int] = (10, 18)

    def to_dict(self) -> dict:
        return {
            "id_col": self.id_col, "date_col": self.date_col,
            "trade_id_col": self.trade_id_col, "mktcap_col": self.mktcap_col,
            "surface_list_col": self.surface_list_col,
            "n_surface_cols": len(self.surface_cols),
            "surface_cols_head": self.surface_cols[:6],
            "surface_cols_tail": self.surface_cols[-3:],
            "target_cols": self.target_cols,
            "surface_shape": list(self.surface_shape),
        }


def _detect_surface_list_col(panel: pd.DataFrame, config: dict) -> Optional[str]:
    """Find a single column whose cells are length-180 lists/arrays
    (e.g. 'ImpliedVolatility'). Returns the column name or None."""
    n_cells = int(np.prod(config["surface_shape"]))
    # prefer a named candidate
    cand = _ci_lookup(list(panel.columns), config.get("surface_list_candidates", []))
    cols_to_try = ([cand] if cand else []) + [c for c in panel.columns if c != cand]
    for c in cols_to_try:
        if c is None:
            continue
        s = panel[c].dropna()
        if len(s) == 0:
            continue
        v = s.iloc[0]
        if isinstance(v, (list, tuple, np.ndarray)):
            try:
                if len(np.ravel(np.asarray(v, dtype=float))) == n_cells:
                    return c
            except Exception:
                continue
    return None


def _detect_surface_cols(panel: pd.DataFrame, config: dict,
                         reserved: Sequence[str]) -> List[str]:
    """Locate the 180 IV-surface columns (when stored as separate columns)."""
    n_cells = int(np.prod(config["surface_shape"]))
    cols = list(panel.columns)

    # 1) prefix-based detection
    prefs = tuple(p.lower() for p in config["surface_prefix"])
    pref_cols = [c for c in cols if str(c).lower().startswith(prefs)]
    if len(pref_cols) == n_cells:
        return pref_cols

    # 2) numeric grid-like names, e.g. "0_0","d3_t11","(0,0)" -> sort stably
    def _is_num(c):
        return pd.api.types.is_numeric_dtype(panel[c])
    numeric_cols = [c for c in cols if c not in reserved and _is_num(c)]
    # drop obvious non-surface numerics (mktcap, ids accidentally numeric)
    numeric_cols = [c for c in numeric_cols if c not in reserved]
    if len(numeric_cols) == n_cells:
        return numeric_cols
    # 3) if MORE than n_cells numeric cols, take the densest contiguous block
    if len(numeric_cols) > n_cells:
        logging.warning("Found %d numeric non-id/target cols; expected %d surface "
                        "cells. Taking the first %d. VERIFY column ordering!",
                        len(numeric_cols), n_cells, n_cells)
        return numeric_cols[:n_cells]
    raise ValueError(
        f"Could not locate {n_cells} surface columns "
        f"(found {len(pref_cols)} by prefix, {len(numeric_cols)} numeric). "
        f"Set CONFIG['surface_prefix'] or pre-name surface columns iv_000..iv_179."
    )


def resolve_schema(panel: pd.DataFrame, config: dict = CONFIG) -> Schema:
    s = Schema()
    s.surface_shape = tuple(config["surface_shape"])
    cols = list(panel.columns)

    s.id_col = _ci_lookup(cols, config["id_candidates"])
    s.date_col = _ci_lookup(cols, config["date_candidates"])
    s.trade_id_col = _ci_lookup(cols, config["trade_id_candidates"])
    s.mktcap_col = _ci_lookup(cols, config["mktcap_candidates"])
    if s.id_col is None:
        raise ValueError(f"No id column found among {config['id_candidates']}. "
                         f"Columns: {cols[:20]}...")
    if s.date_col is None:
        raise ValueError(f"No date column found among {config['date_candidates']}.")

    # targets: keep whichever of the requested targets are present (ci)
    s.target_cols = []
    for t in config["targets"]:
        actual = _ci_lookup(cols, [t])
        if actual is not None:
            s.target_cols.append(actual)
    if not s.target_cols:
        raise ValueError(f"None of the requested targets {config['targets']} found.")

    # Surface: prefer a single length-180 list column ("ImpliedVolatility");
    # otherwise fall back to 180 separate numeric columns.
    s.surface_list_col = _detect_surface_list_col(panel, config)
    if s.surface_list_col is None:
        reserved = [c for c in [s.id_col, s.date_col, s.trade_id_col, s.mktcap_col,
                                "_src_file"] if c]
        reserved += s.target_cols
        reserved += [c for c in cols
                     if str(c).upper().startswith(("TRET", "RET_F", "FRET"))]
        s.surface_cols = _detect_surface_cols(panel, config, reserved)
    return s


def extract_surface_matrix(panel: pd.DataFrame, schema: Schema) -> np.ndarray:
    """Return the (N, 180) IV-surface matrix, whether the surface is stored as
    one length-180 list column or as 180 separate columns. Row order matches
    `panel`."""
    n_cells = int(np.prod(schema.surface_shape))
    if schema.surface_list_col is not None:
        col = panel[schema.surface_list_col].values
        out = np.full((len(col), n_cells), np.nan, dtype=np.float32)
        for i, v in enumerate(col):
            if v is None:
                continue
            a = np.ravel(np.asarray(v, dtype=np.float32))
            if a.size == n_cells:
                out[i] = a
        return out
    return panel[schema.surface_cols].to_numpy(dtype=np.float32)


def apply_stock_subset(panel: pd.DataFrame, schema: Schema, config: dict) -> pd.DataFrame:
    """Keep the first `max_stocks` perm_IDs (sorted) that ALSO have enough data
    in the OOS window, so the testing slice isn't polluted by stocks that are
    absent during the test period."""
    n = config.get("max_stocks")
    if not n:
        return panel
    d = pd.to_datetime(panel[schema.date_col])
    oos_lo = pd.Timestamp(config["oos_start"])
    oos_hi = pd.Timestamp(config["oos_end"])
    in_oos = (d >= oos_lo) & (d < oos_hi)
    min_obs = int(config.get("subset_min_oos_obs", 1))
    oos_counts = panel.loc[in_oos, schema.id_col].value_counts()
    eligible = sorted(oos_counts[oos_counts >= min_obs].index.tolist())
    n_total = panel[schema.id_col].nunique()
    if not eligible:
        logging.warning("No stocks have >= %d OOS obs; falling back to first %d ids.",
                        min_obs, int(n))
        eligible = sorted(panel[schema.id_col].dropna().unique())
    keep = eligible[: int(n)]
    sub = panel[panel[schema.id_col].isin(keep)].copy()
    logging.info("Stock subset: first %d of %d perm_IDs with >=%d OOS obs "
                 "-> %d kept, %d rows (of %d total stocks)",
                 int(n), len(eligible), min_obs, len(keep), len(sub), n_total)
    return sub


def apply_surface_norm(S: np.ndarray, month_codes: np.ndarray,
                       config: dict) -> np.ndarray:
    """Standardise the (N,180) surface per the `surface_norm` policy. All modes
    are leak-free (per-DATE transforms use only that date's cross-section; the
    per-cell train z-score is applied later by PixelScaler)."""
    mode = config.get("surface_norm", "pixel_zscore")
    if mode in ("none", "pixel_zscore"):
        return S                                   # PixelScaler does train z-score
    if mode.startswith("log"):
        S = np.log(np.clip(S, 1e-6, None)).astype(np.float32)
        if mode == "log_pixel":
            return S
    if mode in ("xs_zscore", "log_xs"):
        min_n = int(config.get("xs_min_stocks", 5))
        df = pd.DataFrame(S)
        df["_m"] = month_codes

        def _z(block):
            if len(block) < min_n:
                return block
            mu = block.mean(axis=0)
            sd = block.std(axis=0).replace(0.0, 1.0)
            return (block - mu) / sd
        S = (df.groupby("_m", group_keys=False)
             .apply(lambda g: _z(g.drop(columns="_m")))
             .to_numpy(dtype=np.float32))
    return S


def resample_to_monthly(panel: pd.DataFrame, schema: Schema) -> pd.DataFrame:
    """Collapse to ONE observation per (stock, calendar-month): the last
    available date in that month (month-end IV, per the paper). The date is
    then snapped to the month-end timestamp so all stocks in a month align."""
    df = panel.copy()
    df[schema.date_col] = pd.to_datetime(df[schema.date_col])
    df["_m"] = df[schema.date_col].dt.to_period("M")
    # keep the row with the latest date in each (stock, month)
    idx = df.groupby([schema.id_col, "_m"])[schema.date_col].idxmax()
    last = df.loc[idx].copy()
    last[schema.date_col] = last["_m"].dt.to_timestamp("M")   # snap to month-end
    last = (last.drop(columns=["_m"])
            .sort_values([schema.date_col, schema.id_col])
            .reset_index(drop=True))
    return last


def data_check(config: dict = CONFIG) -> Tuple[pd.DataFrame, Schema, dict]:
    """
    Full data-check + summary. Returns (panel, schema, summary_dict) and writes
    a JSON report, a per-target stats CSV, and diagnostic figures.
    """
    panel = load_raw_panel(config)
    schema = resolve_schema(panel, config)

    # --- normalise date & sort -------------------------------------
    panel[schema.date_col] = pd.to_datetime(panel[schema.date_col])
    panel = panel.sort_values([schema.date_col, schema.id_col]).reset_index(drop=True)

    # --- optional testing subset (first N perm_IDs) ----------------
    n_dates_raw = int(panel[schema.date_col].nunique())
    panel = apply_stock_subset(panel, schema, config)

    # --- monthly resample (optional; default OFF so training keeps all obs) --
    resampled = bool(config.get("resample_monthly", False))
    if resampled:
        before = len(panel)
        panel = resample_to_monthly(panel, schema)
        logging.info("Monthly resample (training): %d -> %d rows (%d unique dates "
                     "-> %d months)", before, len(panel), n_dates_raw,
                     panel[schema.date_col].dt.to_period("M").nunique())
    else:
        logging.info("No training resample: keeping all %d obs (~%.1f per "
                     "stock-month); portfolio still aggregates to month-end.",
                     len(panel),
                     len(panel) / max(1, panel[schema.id_col].nunique()
                                      * panel[schema.date_col].dt.to_period("M").nunique()))

    n_cells = int(np.prod(schema.surface_shape))
    surf = extract_surface_matrix(panel, schema).astype(np.float64)
    found = (1 if schema.surface_list_col else len(schema.surface_cols))
    reshape_ok = (surf.shape[1] == n_cells)

    summary = {
        "schema": schema.to_dict(),
        "surface_storage": ("list_column:" + schema.surface_list_col
                            if schema.surface_list_col else "separate_columns"),
        "n_rows": int(len(panel)),
        "n_stocks": int(panel[schema.id_col].nunique()),
        "date_min": str(panel[schema.date_col].min().date()),
        "date_max": str(panel[schema.date_col].max().date()),
        "n_months": int(panel[schema.date_col].dt.to_period("M").nunique()),
        "n_unique_dates": int(panel[schema.date_col].nunique()),
        "resampled_for_training": resampled,
        "surface_norm": config.get("surface_norm"),
        "maturity_grid": config.get("maturity_grid"),
        "surface_cells_expected": n_cells,
        "surface_cells_found": int(surf.shape[1]),
        "surface_reshape_ok": bool(reshape_ok),
        "surface_nan_frac": float(np.isnan(surf).mean()),
        "surface_neg_frac": float((surf < 0).mean()),   # IV should be >= 0
        "duplicate_id_date": int(panel.duplicated(
            [schema.id_col, schema.date_col]).sum()),
        "avg_stocks_per_month": float(
            panel.groupby(panel[schema.date_col].dt.to_period("M"))[schema.id_col]
            .nunique().mean()),
    }

    # --- per-target stats ------------------------------------------
    tgt_rows = []
    for t in schema.target_cols:
        v = pd.to_numeric(panel[t], errors="coerce")
        tgt_rows.append({
            "target": t,
            "n_obs": int(v.notna().sum()),
            "nan_frac": float(v.isna().mean()),
            "mean": float(v.mean()), "std": float(v.std()),
            "min": float(v.min()), "p1": float(v.quantile(0.01)),
            "p50": float(v.median()), "p99": float(v.quantile(0.99)),
            "max": float(v.max()),
        })
    tgt_df = pd.DataFrame(tgt_rows)
    summary["targets"] = tgt_rows

    # --- write reports ---------------------------------------------
    with open(os.path.join(config["output_dir"], "data_check.json"), "w") as fh:
        json.dump(summary, fh, indent=2, default=str)
    tgt_df.to_csv(os.path.join(config["output_dir"], "target_stats.csv"), index=False)

    # --- figures ---------------------------------------------------
    try:
        _data_check_figures(panel, schema, config)
    except Exception as exc:
        logging.warning("data-check figures skipped: %s", exc)

    # --- loud console banner ---------------------------------------
    _print_data_check(summary, schema)
    return panel, schema, summary


