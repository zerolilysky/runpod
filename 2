def _in_jupyter() -> bool:
    if "ipykernel" in sys.modules or "IPython" in sys.modules:
        return True
    a0 = (sys.argv[0] or "").lower()
    return any(k in a0 for k in ["ipykernel", "jupyter", "colab"])


def main():
    ap = argparse.ArgumentParser(description="IV-surface multi-model return forecasting")
    ap.add_argument("stage", nargs="?", default="all",
                    choices=["check", "run", "all", "smoke"])
    ap.add_argument("--data-dir", default=None)
    ap.add_argument("--models", default=None, help="comma list, or 'all'")
    ap.add_argument("--targets", default=None, help="comma list")
    ap.add_argument("--window", default=None,
                    choices=["expanding", "rolling", "single"])
    ap.add_argument("--max-train-years", type=int, default=None,
                    help="cap the expanding window to this many trailing years")
    ap.add_argument("--roll-years", type=int, default=None,
                    help="trailing window length for --window rolling")
    ap.add_argument("--ensemble-k", type=int, default=None)
    ap.add_argument("--refit-every", type=int, default=None,
                    help="retrain every k months (1=every month, paper)")
    ap.add_argument("--cuda", action="store_true", help="use a GPU (default: CPU-only)")
    ap.add_argument("--no-cuda", action="store_true", help="force CPU-only (default)")
    ap.add_argument("--n-cpus", type=int, default=None,
                    help="cores for CPU-distributed training (default: all)")
    ap.add_argument("--max-stocks", type=int, default=None,
                    help="use only the first N perm_IDs (quick testing subset)")
    ap.add_argument("--workers", type=int, default=None)
    ap.add_argument("--force-rebuild", action="store_true")
    args, _ = ap.parse_known_args()

    if args.data_dir:
        CONFIG["data_dir"] = args.data_dir
    if args.max_stocks is not None:
        CONFIG["max_stocks"] = args.max_stocks
    if args.models:
        CONFIG["models"] = CONFIG["all_models"] if args.models == "all" \
            else [m.strip() for m in args.models.split(",")]
    if args.targets:
        CONFIG["targets"] = [t.strip() for t in args.targets.split(",")]
    if args.window:
        CONFIG["window_scheme"] = args.window
    if args.max_train_years is not None:
        CONFIG["max_train_years"] = args.max_train_years
    if args.roll_years is not None:
        CONFIG["roll_years"] = args.roll_years
    if args.ensemble_k is not None:
        CONFIG["ensemble_K"] = args.ensemble_k
    if args.refit_every is not None:
        CONFIG["refit_every"] = args.refit_every
    if args.cuda:
        CONFIG["use_cuda"] = True
    if args.no_cuda:
