# Section 13 - Synthetic data generator (smoke-test / demo)
# ======================================================================
def make_synthetic_dataset(out_dir: str, n_stocks: int = 120, n_months: int = 96,
                           shape: Tuple[int, int] = (10, 18), seed: int = 0,
                           signal: float = 0.15) -> str:
    """
    Create a tiny synthetic panel mimicking the real schema so the whole
    pipeline can be smoke-tested without OptionMetrics access. A weak,
    learnable signal links a smooth surface functional to forward returns.
    Writes one pickle per stock and returns the directory.
    """
    rng = np.random.default_rng(seed)
    os.makedirs(out_dir, exist_ok=True)
    H, W = shape                         # H = maturity (10), W = delta (18)
    n_cells = H * W
    months = pd.period_range("2000-01", periods=n_months, freq="M")
    # a fixed "loading" surface defining the true predictive functional
    gd = np.linspace(-1, 1, H)[:, None]
    gt = np.linspace(-1, 1, W)[None, :]
    loading = (np.exp(-(gd ** 2)) * np.cos(2 * gt)).reshape(-1)
    loading /= np.linalg.norm(loading)

    for sid in range(n_stocks):
        base = 0.2 + 0.05 * rng.standard_normal()
        rows = []
        for mp in months:
            # mimic real data: a few intra-month dates; resample keeps the last
            n_obs = rng.integers(1, 4)
            obs_days = sorted(rng.choice(range(1, 27), size=n_obs, replace=False))
            term = 0.10 * np.exp(-0.5 * (np.linspace(0, 1, W)))[None, :]
            smile = 0.08 * (np.linspace(-1, 1, H) ** 2)[:, None]
            for day in obs_days:
                dt = pd.Timestamp(mp.to_timestamp()) + pd.Timedelta(days=int(day) - 1)
                surf = (base + term + smile +
                        0.03 * rng.standard_normal((H, W))).clip(0.02, None)
                flat = surf.reshape(-1).astype(np.float32)       # maturity-major
                score = float(flat @ loading)
                fwd20 = signal * score + 0.04 * rng.standard_normal()
                fwd5 = 0.5 * fwd20 + 0.03 * rng.standard_normal()
                mkt = 0.005 * rng.standard_normal()
                rows.append({
                    "perm_ID": 10000 + sid, "date": dt,
                    "trade_id": f"{10000+sid}_{dt.date()}",
                    "mktcap": float(np.exp(6 + 2 * rng.random())),
                    # surface stored as ONE length-180 list column, like the real data
                    "ImpliedVolatility": flat.tolist(),
                    "TRET_F20D": fwd20, "TRET_SP500_EX_F20D": fwd20 - mkt,
                    "TRET_F5D": fwd5, "TRET_SP500_EX_F5D": fwd5 - mkt})
        df = pd.DataFrame(rows)
        df.to_pickle(os.path.join(out_dir, f"{10000+sid}_all_Count_w_fReturns.pickle"))
    logging.info("Synthetic dataset: %d stocks x %d months (list-column surface) -> %s",
                 n_stocks, n_months, out_dir)
    return out_dir


